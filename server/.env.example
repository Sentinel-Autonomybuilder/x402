# x402 VPN Server — Environment Variables

# ─── Base Chain (USDC payments) ───
# Your EVM wallet address where USDC payments are received
OPERATOR_ADDRESS=0x...

# Network: eip155:8453 = Base mainnet (default), eip155:84532 = Base Sepolia
BASE_NETWORK=eip155:8453

# ─── Facilitator (pick ONE) ───

# Option 1: Self-hosted (recommended — fully decentralized, no third party)
# EVM private key with ETH on Base for settlement gas
FACILITATOR_PRIVATE_KEY=0x...
FACILITATOR_PORT=4021

# Option 2: CDP (Coinbase-hosted facilitator)
# CDP_API_KEY_ID=
# CDP_API_KEY_SECRET=

# Option 3: x402.org (Base Sepolia testnet only)
# No config needed — used as fallback on Sepolia

# ─── Sentinel Chain (VPN provisioning) ───
# Operator wallet mnemonic — must have P2P tokens for gas
# This wallet owns the plan and creates subscriptions/fee grants
SENTINEL_OPERATOR_MNEMONIC=word1 word2 word3 ... word12

# Plan ID on Sentinel chain — contains the leased nodes
SENTINEL_PLAN_ID=42

# Sentinel RPC/LCD endpoints
SENTINEL_RPC_URL=https://rpc.sentinel.co:443
SENTINEL_LCD_URL=https://lcd.sentinel.co

# ─── Server ───
PORT=4020
